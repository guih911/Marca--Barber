# Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/zenvix_db"

# JWT
JWT_SECRET="sua_chave_secreta_jwt_muito_segura_aqui"
JWT_REFRESH_SECRET="sua_chave_secreta_refresh_muito_segura_aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="seu_google_client_id"
GOOGLE_CLIENT_SECRET="seu_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Claude API
ANTHROPIC_API_KEY="sua_chave_anthropic_aqui"
ANTHROPIC_MODEL="claude-3-5-haiku-latest"
ANTHROPIC_MODEL_COMPLEXO="claude-3-7-sonnet-latest"

# Gemini/OpenAI compatível (usado por módulos auxiliares)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Email (Nodemailer)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="seu@email.com"
EMAIL_PASS="sua_senha_de_app"
EMAIL_FROM="Zenvix <noreply@zenvix.com>"

# App
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
