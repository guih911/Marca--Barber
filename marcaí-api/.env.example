# Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/zenvix_db"

# JWT
JWT_SECRET="sua_chave_secreta_jwt_muito_segura_aqui"
JWT_REFRESH_SECRET="sua_chave_secreta_refresh_muito_segura_aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="seu_google_client_id"
GOOGLE_CLIENT_SECRET="seu_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Gemini/OpenAI compatível (usado por módulos auxiliares; NÃO é Whisper)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# OpenAI: obrigatório para transcrição de voz (Whisper) no WhatsApp; independente do Gemini
OPENAI_API_KEY=""
# OPENAI_BASE_URL=""  # opcional (ex.: proxy); vazio = api.openai.com

# LLM principal da recepcionista (Anthropic Claude)
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
ANTHROPIC_MODEL_COMPLEXO="claude-sonnet-4-6"

# Email (Nodemailer)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="seu@email.com"
EMAIL_PASS="sua_senha_de_app"
EMAIL_FROM="Zenvix <noreply@zenvix.com>"

# App
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
# URL pública do backend (HTTPS em produção). Usada para exibir a URL exata do webhook no painel.
# Deve bater com META_WEBHOOK_CALLBACK_URL (caminho /api/ia/webhook/meta)
API_PUBLIC_BASE_URL="http://localhost:3001"
# Atrás de Caddy/nginx: 1 = Express usa X-Forwarded-For (recom. em produção)
TRUST_PROXY="0"

# Meta WhatsApp Cloud API (oficial)
META_GRAPH_API_VERSION="v22.0"
META_APP_ID=""
META_APP_SECRET=""
META_EMBEDDED_SIGNUP_CONFIG_ID=""
META_WEBHOOK_VERIFY_TOKEN=""
# Deve ser acessível na internet; mesma URL no painel da Meta (Webhooks) + field "messages"
META_WEBHOOK_CALLBACK_URL="http://localhost:3001/api/ia/webhook/meta"

# Facebook OAuth
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:3001/api/auth/facebook/callback"
# Deve ser idêntico a um "Valid OAuth Redirect URI" (ex.: a página /config/integracoes do app)
OAUTH_REDIRECT_URL="http://localhost:5173/config/integracoes"
# Opcional: hosts adicionais (punycode) se APP_URL (IDN) e a barra do browser divergirem na comparaçao
# META_OAUTH_EXTRA_REDIRECT_HOSTS=barber.xn--marca-3sa.com
