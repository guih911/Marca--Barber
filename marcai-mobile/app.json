{
  "expo": {
    "name": "marcai-mobile",
    "slug": "marcai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B8894D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marcai.barber"
    },
    "android": {
      "package": "com.marcai.barber",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B8894D"
      },
      "edgeToEdgeEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#B8894D"
        }
      ]
    ],
    "extra": {
      "apiBase": "https://barber.xn--marca-3sa.com"
    }
  }
}
