# ═══════════════════════════════════════════════════════════════════════════════
# Marcaí Barber — Variáveis de Produção
# Copie para .env e preencha os valores reais
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=marcai_prod
POSTGRES_USER=marcai
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_COM_32_CHARS

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://marcai:TROQUE_POR_SENHA_FORTE_COM_32_CHARS@postgres:5432/marcai_prod
JWT_SECRET=TROQUE_POR_64_CHARS_ALEATORIOS_AQUI_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_64_CHARS_ALEATORIOS_XXXXXXXXXXXXXXXXXXXXXXXXXX
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://barber.marcaí.com

# ── Gemini IA ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── Email (opcional) ──────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ── Puppeteer / WhatsApp (definido automaticamente pelo Docker) ───────────────
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
