# ═══════════════════════════════════════════════════════════════════════════════
# Marcaí Barber — Variáveis de Produção
# Copie para .env e preencha os valores reais
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=marcai_prod
POSTGRES_USER=marcai
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_COM_32_CHARS

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://marcai:TROQUE_POR_SENHA_FORTE_COM_32_CHARS@postgres:5432/marcai_prod
JWT_SECRET=TROQUE_POR_64_CHARS_ALEATORIOS_AQUI_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_64_CHARS_ALEATORIOS_XXXXXXXXXXXXXXXXXXXXXXXXXX
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://barber.marcaí.com

# ── IA compatível OpenAI (módulos auxiliares legados) ────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# ── Email (opcional) ──────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ── Meta WhatsApp Cloud API (oficial) ────────────────────────────────────────
# Use o Embedded Signup da Meta para conectar cada barbearia sem QR Code
META_GRAPH_API_VERSION=v22.0
META_APP_ID=seu_meta_app_id
META_APP_SECRET=seu_meta_app_secret
META_EMBEDDED_SIGNUP_CONFIG_ID=seu_embedded_signup_config_id
META_WEBHOOK_VERIFY_TOKEN=um_token_secreto_para_validar_o_webhook
META_WEBHOOK_CALLBACK_URL=https://barber.marcaí.com/api/ia/webhook/meta

# ── Facebook OAuth ────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=seu_facebook_app_id
FACEBOOK_APP_SECRET=seu_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://barber.xn--marca-3sa.com/api/auth/facebook/callback
OAUTH_REDIRECT_URL=https://barber.xn--marca-3sa.com

# ── Puppeteer / WhatsApp (definido automaticamente pelo Docker) ───────────────
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
